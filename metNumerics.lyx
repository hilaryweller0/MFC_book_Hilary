\begin_inset CommandInset ref
LatexCommand ref
reference "subsec:Ex_CTCSadvection"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

.
 Explore how the errors depend on Courant number for each scheme.
 
\end_layout

